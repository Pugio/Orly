# TableLight environment variables
# Copy to .env and fill in your values.

# Gemini API key (for local development)
# Get one at https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_API_KEY=

# IP Webcam URL (Android phone camera)
PHONE_IP=http://192.168.0.100:8080

# Backend WebSocket URL
BACKEND_URL=ws://localhost:8080/ws/session

# Google Cloud settings (for Cloud Run deployment)
GCP_PROJECT_ID=
GCP_REGION=us-central1
